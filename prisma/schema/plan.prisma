model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Float
  currency      String         @default("USD")
  interval      BillingInterval
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]

  @@map("plan")
  
}